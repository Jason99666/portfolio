---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="文章 - 梁啸雨" description="AI 产品思考与技术分享 - 公众号「碳基手记」">
  <header style="margin-bottom: var(--spacing-2xl);">
    <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: var(--spacing-sm);">文章</h1>
    <p style="font-size: 0.875rem; color: var(--color-text-secondary);">
      以下文章首发于个人公众号「碳基手记」，点击卡片即可阅读
    </p>
  </header>

  <div style="display: flex; flex-direction: column; gap: var(--spacing-lg); max-width: 720px;">
    {posts.map((post) => {
      const href = post.data.externalUrl || `/blog/${post.slug}`;
      const target = post.data.externalUrl ? '_blank' : undefined;
      const rel = post.data.externalUrl ? 'noopener noreferrer' : undefined;

      return (
        <a
          href={href}
          target={target}
          rel={rel}
          style="text-decoration: none; color: inherit; display: block;"
        >
          <article
            style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--spacing-lg); display: flex; gap: var(--spacing-lg); transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;"
            onmouseover="this.style.boxShadow='var(--shadow-md)'; this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-accent)'"
            onmouseout="this.style.boxShadow='none'; this.style.transform='translateY(0)'; this.style.borderColor='var(--color-border)'"
          >
            {/* 日期侧边栏 */}
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 60px; padding: var(--spacing-sm); background: var(--color-surface); border-radius: var(--radius); text-align: center;">
              <span style="font-size: 1.5rem; font-weight: 700; color: var(--color-accent); line-height: 1;">
                {post.data.date.getDate()}
              </span>
              <span style="font-size: 0.7rem; color: var(--color-text-secondary); text-transform: uppercase;">
                {post.data.date.toLocaleDateString('zh-CN', { month: 'short' })}
              </span>
              <span style="font-size: 0.65rem; color: var(--color-text-secondary);">
                {post.data.date.getFullYear()}
              </span>
            </div>

            {/* 内容区域 */}
            <div style="flex: 1; min-width: 0;">
              <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: var(--spacing-sm); line-height: 1.4;">
                {post.data.title}
              </h3>
              <p style="font-size: 0.875rem; color: var(--color-text-secondary); margin-bottom: var(--spacing-md); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {post.data.excerpt}
              </p>
              <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--spacing-xs);">
                {post.data.tags && post.data.tags.map((tag: string) => (
                  <span style="font-size: 0.7rem; padding: 0.125rem 0.5rem; background: var(--color-surface); color: var(--color-text-secondary); border-radius: 9999px; border: 1px solid var(--color-border);">
                    {tag}
                  </span>
                ))}
                {post.data.externalUrl && (
                  <span style="font-size: 0.7rem; color: var(--color-accent); margin-left: auto; display: flex; align-items: center; gap: 0.25rem;">
                    阅读原文 &rarr;
                  </span>
                )}
              </div>
            </div>
          </article>
        </a>
      );
    })}
  </div>
</BaseLayout>
