---
const navLinks = [
  { href: '/projects', label: '项目' },
  { href: '/blog', label: '文章' },
  { href: '/about', label: '关于' },
];
---

<header style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); border-bottom: 1px solid var(--color-border);">
  <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 4rem;">
    <a href="/" style="font-size: 1.125rem; font-weight: 600; color: var(--color-text); text-decoration: none;">
      梁啸雨
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav" style="display: flex; gap: var(--spacing-xl);">
      {navLinks.map((link) => (
        <a
          href={link.href}
          style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none; font-weight: 500;"
          class:list={[{ active: Astro.url.pathname === link.href || (link.href !== '/' && Astro.url.pathname.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav -->
    <details class="mobile-nav" style="display: none;">
      <summary style="cursor: pointer; padding: var(--spacing-sm); font-size: 1.25rem; list-style: none;">&#9776;</summary>
      <nav style="display: flex; flex-direction: column; gap: var(--spacing-md); padding: var(--spacing-md); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); margin-top: var(--spacing-sm);">
        {navLinks.map((link) => (
          <a
            href={link.href}
            style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none; font-weight: 500; padding: var(--spacing-sm) 0;"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>

<style>
  .active {
    color: var(--color-accent) !important;
  }

  @media (max-width: 768px) {
    .desktop-nav {
      display: none !important;
    }
    .mobile-nav {
      display: block !important;
    }
  }
</style>
